// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  password               String
  fullName               String
  role                   Role
  clinic                 Clinic?                 @relation(fields: [clinicId], references: [id])
  clinicId               String?
  vetProfile             Vet?                    @relation("VetProfile")
  vetId                  String?                 @unique
  pets                   Pet[]                   @relation("OwnerPets")
  appointments           Appointment[]           @relation("OwnerAppointments")
  notificationPreference NotificationPreference?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Clinic {
  id           String        @id @default(uuid())
  users        User[]
  name         String
  email        String        @unique
  phone        String
  address      String
  city         String
  zipCode      String
  emergency    Boolean       @default(false)
  vets         Vet[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Vet {
  id             String         @id @default(uuid())
  name           String
  specialization String?
  availability   Availability[]
  appointments   Appointment[]
  clinic         Clinic         @relation(fields: [clinicId], references: [id])
  clinicId       String
  user           User?          @relation("VetProfile", fields: [userId], references: [id])
  userId         String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Availability {
  id        String  @id @default(uuid())
  day       Weekday
  startTime String
  endTime   String
  vet       Vet     @relation(fields: [vetId], references: [id])
  vetId     String
}

model Pet {
  id           String        @id @default(uuid())
  name         String
  species      String
  breed        String?
  birthDate    DateTime
  owner        User          @relation("OwnerPets", fields: [ownerId], references: [id])
  ownerId      String
  appointments Appointment[]
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id               String            @id @default(uuid())
  date             DateTime
  endTime          DateTime
  duration         Int
  reason           String
  emergency        Boolean           @default(false)
  pet              Pet               @relation(fields: [petId], references: [id])
  petId            String
  owner            User              @relation("OwnerAppointments", fields: [ownerId], references: [id])
  ownerId          String
  clinic           Clinic            @relation(fields: [clinicId], references: [id])
  clinicId         String
  vet              Vet               @relation(fields: [vetId], references: [id])
  vetId            String
  status           AppointmentStatus @default(PENDING)
  notificationLogs NotificationLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  emailEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NotificationLog {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  sentVia       String // 'email'
  sentAt        DateTime    @default(now())
  success       Boolean
  detail        String?
}

enum Role {
  OWNER
  VET
  CLINIC_ADMIN
  SUPER_ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
