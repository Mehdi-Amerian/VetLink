{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "lint-staged": {
    "openapi.yaml": [
      "redocly lint openapi.yaml"
    ],
    "src/**/*.{ts,tsx}": [
      "npm run -s build --if-present",
      "git add"
    ]
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "seed:dev": "cross-env NODE_ENV=development prisma db seed",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "openapi:lint": "npx redocly lint openapi.yaml --config redocly.yaml",
    "openapi:sdk": "npx openapi-typescript ./openapi.yaml -o ./src/sdk/types.ts",
    "sdk": "npm run openapi:lint && npm run openapi:sdk"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@redocly/cli": "^2.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.22",
    "@types/jest": "^30.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.19",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "jest": "^30.0.0",
    "lint-staged": "^16.1.6",
    "openapi-typescript": "^7.9.1",
    "redoc": "^2.5.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@sendgrid/mail": "^8.1.5",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "prisma": "^6.8.2",
    "resend": "^6.9.3",
    "zod": "^3.25.7"
  }
}
